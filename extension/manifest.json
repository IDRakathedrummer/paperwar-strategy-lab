{
  "manifest_version": 3,
  "name": "PaperWar Capture Bridge",
  "version": "1.0",
  "description": "Bridges userscript API calls to localhost:8000, bypassing Chrome Private Network Access restrictions.",
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "http://paper.hosted-by-fern.host/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://paper.hosted-by-fern.host/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
